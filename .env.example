# Picasso Analytics Dashboard Environment Variables

# Analytics API endpoint. Default '/api' routes through CloudFront to the Lambda
# (same-origin). Override with an absolute Lambda URL only for local dev when
# CloudFront isn't in front of the dev server.
VITE_ANALYTICS_API_URL=/api

# Bubble SSO authentication URL (optional - enables "Sign in with MyRecruiter" button)
# Users will be redirected here for authentication, then back with ?token=JWT
VITE_BUBBLE_AUTH_URL=

# Development mode (enables mock data and debug features)
VITE_DEV_MODE=false

# Session Timeline Feature Flag (User Journey Analytics)
# Set to 'true' to enable the new sessions list with detailed event timelines
# This replaces the RecentConversations component with richer session data
VITE_USE_SESSIONS_API=false

# Pinned origin for the calendar OAuth connect/status URLs (Settings → Calendar).
# Must EXACTLY match the origin of the backend's OAUTH_FUNCTION_URL — the friendly
# scheduling domain fronting the OAuth Lambda (no trailing slash — URL.origin has
# none). Unset → code default (staging.schedule.myrecruiter.ai).
VITE_OAUTH_ORIGIN=
